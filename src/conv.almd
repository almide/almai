// almai.conv — Conversation builder for multi-turn interactions

// ── Types ──

type Conversation = {
  messages: List[Message],
}

type Message = {
  role: String,
  content: String,
}

// ── Constructors ──

fn empty() -> Conversation = Conversation { messages: [] }

fn from_messages(msgs: List[Message]) -> Conversation =
  Conversation { messages: msgs }

// ── Builder ──

fn add(conv: Conversation, role: String, content: String) -> Conversation =
  Conversation { messages: conv.messages + [Message { role: role, content: content }] }

fn add_system(conv: Conversation, content: String) -> Conversation =
  add(conv, "system", content)

fn add_user(conv: Conversation, content: String) -> Conversation =
  add(conv, "user", content)

fn add_assistant(conv: Conversation, content: String) -> Conversation =
  add(conv, "assistant", content)

fn add_tool_result(conv: Conversation, tool_call_id: String, content: String) -> Conversation =
  Conversation { messages: conv.messages + [Message { role: "tool", content: content }] }

// ── Query ──

fn messages(conv: Conversation) -> List[Message] = conv.messages

fn len(conv: Conversation) -> Int = list.len(conv.messages)

fn last_role(conv: Conversation) -> Option[String] =
  list.last(conv.messages) |> option.map((m) => m.role)

fn last_content(conv: Conversation) -> Option[String] =
  list.last(conv.messages) |> option.map((m) => m.content)

fn system_prompt(conv: Conversation) -> String =
  conv.messages
    |> list.find((m) => m.role == "system")
    |> option.map((m) => m.content)
    |> option.unwrap_or("")

fn user_messages(conv: Conversation) -> List[Message] =
  list.filter(conv.messages, (m) => m.role == "user")

fn without_system(conv: Conversation) -> List[Message] =
  list.filter(conv.messages, (m) => m.role != "system")

// ── Tests ──

test "new creates empty conversation" {
  assert_eq(len(empty()), 0)
}

test "add_system adds system message" {
  let c = empty() |> add_system("You are helpful.")
  assert_eq(len(c), 1)
  assert_eq(last_role(c), some("system"))
}

test "builder chain" {
  let c = empty()
    |> add_system("System prompt")
    |> add_user("Hello")
    |> add_assistant("Hi there")
    |> add_user("How are you?")
  assert_eq(len(c), 4)
  assert_eq(last_role(c), some("user"))
  assert_eq(last_content(c), some("How are you?"))
}

test "system_prompt extracts system" {
  let c = empty() |> add_system("Be concise.") |> add_user("Hi")
  assert_eq(system_prompt(c), "Be concise.")
}

test "system_prompt returns empty when none" {
  let c = empty() |> add_user("Hi")
  assert_eq(system_prompt(c), "")
}

test "without_system filters" {
  let c = empty() |> add_system("Sys") |> add_user("Hi") |> add_assistant("Hello")
  let filtered = without_system(c)
  assert_eq(list.len(filtered), 2)
}

test "user_messages filters" {
  let c = empty() |> add_system("Sys") |> add_user("A") |> add_assistant("B") |> add_user("C")
  assert_eq(list.len(user_messages(c)), 2)
}

test "from_messages preserves order" {
  let msgs = [
    Message { role: "user", content: "a" },
    Message { role: "assistant", content: "b" },
  ]
  let c = from_messages(msgs)
  assert_eq(len(c), 2)
  assert_eq(last_content(c), some("b"))
}
