// almai — Multi-provider LLM client for Almide
//
// Usage:
//   import almai
//
//   let r = almai.call("anthropic/claude-sonnet-4-6", [
//     almai.system("You are helpful."),
//     almai.user("Hello"),
//   ])!
//   println(r.content)
//
// Providers:
//   anthropic/{model}            Anthropic Messages API
//   openai/{model}               OpenAI Chat Completions
//   openrouter/{model}           OpenRouter (100+ models)
//   cf/{model}                   Cloudflare Workers AI
//   azure/{deployment}           Azure OpenAI
//   google/{model}               Google Gemini
//   cli/claude                   Claude Code CLI
//   cli/codex                    Codex CLI
//
// Submodules:
//   almai.tools  — Tool/function calling types and JSON builders
//   almai.conv   — Conversation builder for multi-turn interactions

import env
import http
import json
import process
import self.providers.cli as cli

// ── Core types ──

type Message = {
  role: String,
  content: String,
}

type LLMResponse = {
  content: String,
  model: String,
  usage: Usage,
  finish_reason: String,
  tool_calls: List[ToolCall],
}

type Usage = {
  prompt_tokens: Int,
  completion_tokens: Int,
  total_tokens: Int,
}

type ToolCall = {
  id: String,
  name: String,
  arguments: String,
}

type Tool = {
  name: String,
  description: String,
  parameters: Value,
}

type CallOptions = {
  max_tokens: Int,
  temperature: Float,
  top_p: Float,
  system: String,
  stop: List[String],
  tools: List[Tool],
  json_mode: Bool,
}

// ── Message constructors ──

fn system(content: String) -> Message =
  Message { role: "system", content: content }

fn user(content: String) -> Message =
  Message { role: "user", content: content }

fn assistant(content: String) -> Message =
  Message { role: "assistant", content: content }

fn tool_result(tool_call_id: String, content: String) -> Message =
  Message { role: "tool", content: content }

// ── Options builder ──

fn defaults() -> CallOptions =
  CallOptions {
    max_tokens: 4096, temperature: 0.0, top_p: 1.0,
    system: "", stop: [], tools: [], json_mode: false,
  }

fn with_max_tokens(opts: CallOptions, n: Int) -> CallOptions =
  { ...opts, max_tokens: n }

fn with_temperature(opts: CallOptions, t: Float) -> CallOptions =
  { ...opts, temperature: t }

fn with_top_p(opts: CallOptions, p: Float) -> CallOptions =
  { ...opts, top_p: p }

fn with_system(opts: CallOptions, s: String) -> CallOptions =
  { ...opts, system: s }

fn with_stop(opts: CallOptions, sequences: List[String]) -> CallOptions =
  { ...opts, stop: sequences }

fn with_tools(opts: CallOptions, ts: List[Tool]) -> CallOptions =
  { ...opts, tools: ts }

fn with_json_mode(opts: CallOptions) -> CallOptions =
  { ...opts, json_mode: true }

// ── Internal: provider parsing ──

fn parse_provider(model_spec: String) -> (String, String) = {
  let idx = string.index_of(model_spec, "/") |> option.unwrap_or(-1)
  if idx < 0 then ("openai", model_spec)
  else (string.take(model_spec, idx), string.drop(model_spec, idx + 1))
}

// ── Internal: JSON helpers ──

fn messages_to_json(msgs: List[Message]) -> Value =
  json.array(list.map(msgs, (m) =>
    json.object([("role", json.from_string(m.role)), ("content", json.from_string(m.content))])
  ))

fn tools_to_json(ts: List[Tool]) -> Value =
  json.array(list.map(ts, (t) =>
    json.object([
      ("type", json.from_string("function")),
      ("function", json.object([
        ("name", json.from_string(t.name)),
        ("description", json.from_string(t.description)),
        ("parameters", t.parameters),
      ])),
    ])
  ))

fn extract_string(v: Value, key: String) -> String =
  json.get_string(v, key) |> option.unwrap_or("")

fn extract_int(v: Value, key: String) -> Int =
  json.get_int(v, key) |> option.unwrap_or(0)

fn parse_usage(v: Value) -> Usage = {
  let u = json.get(v, "usage") |> option.unwrap_or(json.null())
  Usage {
    prompt_tokens: extract_int(u, "prompt_tokens"),
    completion_tokens: extract_int(u, "completion_tokens"),
    total_tokens: extract_int(u, "total_tokens"),
  }
}

fn parse_tool_calls(msg: Value) -> List[ToolCall] =
  json.get_array(msg, "tool_calls")
    |> option.unwrap_or([])
    |> list.filter_map((tc) => {
      let id = json.get_string(tc, "id") |> option.unwrap_or("")
      let func = json.get(tc, "function") |> option.unwrap_or(json.null())
      let name = json.get_string(func, "name") |> option.unwrap_or("")
      let args = json.get_string(func, "arguments") |> option.unwrap_or("{}")
      if name != "" then some(ToolCall { id: id, name: name, arguments: args })
      else none
    })

fn empty_usage() -> Usage =
  Usage { prompt_tokens: 0, completion_tokens: 0, total_tokens: 0 }

fn empty_response(content: String, model: String) -> LLMResponse =
  LLMResponse {
    content: string.trim(content), model: model,
    usage: empty_usage(), finish_reason: "stop", tool_calls: [],
  }

// ── Internal: env + HTTP ──

effect fn require_env(key: String) -> Result[String, String] =
  match env.get(key) {
    some(v) => if v == "" then err("empty env: " + key) else ok(v)
    none => err("missing env: " + key)
  }

effect fn post_json(url: String, body: Value, headers: Map[String, String]) -> Result[Value, String] =
  match http.request("POST", url, json.stringify(body), headers) {
    err(e) => err("http: " + e)
    ok(raw) => match json.parse(raw) {
      err(e) => err("json: " + e + " raw: " + string.take(raw, 200))
      ok(parsed) => {
        let api_err = json.get(parsed, "error")
          |> option.flat_map((e) => json.get_string(e, "message"))
        match api_err {
          some(msg) => err("api: " + msg)
          none => ok(parsed)
        }
      }
    }
  }

// ── Provider: OpenAI-compatible (OpenAI, OpenRouter) ──

effect fn call_openai_compat(
  base_url: String, api_key: String,
  model: String, msgs: List[Message], opts: CallOptions,
) -> Result[LLMResponse, String] = {
  let sys_msgs = if opts.system != "" then [system(opts.system)] else []
  let all_msgs = sys_msgs + msgs
  let fields = [
    ("model", json.from_string(model)),
    ("messages", messages_to_json(all_msgs)),
    ("max_tokens", json.from_int(opts.max_tokens)),
    ("temperature", json.from_float(opts.temperature)),
  ]
  let fields = if not list.is_empty(opts.tools) then fields + [("tools", tools_to_json(opts.tools))] else fields
  let fields = if opts.json_mode then fields + [("response_format", json.object([("type", json.from_string("json_object"))]))] else fields
  let fields = if not list.is_empty(opts.stop) then fields + [("stop", json.array(list.map(opts.stop, (s) => json.from_string(s))))] else fields
  let body = json.object(fields)
  let headers: Map[String, String] = ["Authorization": "Bearer " + api_key, "Content-Type": "application/json"]
  match post_json(base_url + "/chat/completions", body, headers) {
    err(e) => err(e)
    ok(parsed) => {
      let choice = json.get_array(parsed, "choices")
        |> option.flat_map((cs) => list.first(cs))
        |> option.unwrap_or(json.null())
      let msg = json.get(choice, "message") |> option.unwrap_or(json.null())
      ok(LLMResponse {
        content: string.trim(extract_string(msg, "content")),
        model: extract_string(parsed, "model"),
        usage: parse_usage(parsed),
        finish_reason: extract_string(choice, "finish_reason"),
        tool_calls: parse_tool_calls(msg),
      })
    }
  }
}

// ── Provider: Anthropic Messages API ──

effect fn call_anthropic(
  model: String, msgs: List[Message], opts: CallOptions,
) -> Result[LLMResponse, String] =
  match require_env("ANTHROPIC_API_KEY") {
    err(e) => err(e)
    ok(api_key) => {
      let user_msgs = list.filter(msgs, (m) => m.role != "system")
      let sys = if opts.system != "" then opts.system
        else list.find(msgs, (m) => m.role == "system")
          |> option.map((m) => m.content) |> option.unwrap_or("")
      let fields = [
        ("model", json.from_string(model)),
        ("max_tokens", json.from_int(opts.max_tokens)),
        ("messages", messages_to_json(user_msgs)),
      ]
      let fields = if sys != "" then fields + [("system", json.from_string(sys))] else fields
      let fields = if not list.is_empty(opts.tools) then
        fields + [("tools", json.array(list.map(opts.tools, (t) =>
          json.object([
            ("name", json.from_string(t.name)),
            ("description", json.from_string(t.description)),
            ("input_schema", t.parameters),
          ])
        )))]
      else fields
      let body = json.object(fields)
      let headers: Map[String, String] = [
        "x-api-key": api_key, "anthropic-version": "2023-06-01", "Content-Type": "application/json",
      ]
      match post_json("https://api.anthropic.com/v1/messages", body, headers) {
        err(e) => err("anthropic: " + e)
        ok(parsed) => {
          let blocks = json.get_array(parsed, "content") |> option.unwrap_or([])
          let text = blocks
            |> list.filter_map((b) => if extract_string(b, "type") == "text" then json.get_string(b, "text") else none)
            |> string.join("")
          let tool_calls = blocks
            |> list.filter_map((b) =>
              if extract_string(b, "type") == "tool_use" then
                some(ToolCall {
                  id: extract_string(b, "id"),
                  name: extract_string(b, "name"),
                  arguments: json.get(b, "input") |> option.map((v) => json.stringify(v)) |> option.unwrap_or("{}"),
                })
              else none
            )
          ok(LLMResponse {
            content: string.trim(text),
            model: extract_string(parsed, "model"),
            usage: parse_usage(parsed),
            finish_reason: extract_string(parsed, "stop_reason"),
            tool_calls: tool_calls,
          })
        }
      }
    }
  }

// ── Provider: Cloudflare Workers AI ──

effect fn resolve_cf_account() -> Result[String, String] =
  match require_env("CF_ACCOUNT_ID") {
    ok(v) => ok(v)
    err(_) => require_env("CLOUDFLARE_ACCOUNT_ID")
  }

effect fn call_cloudflare(
  model: String, msgs: List[Message], opts: CallOptions,
) -> Result[LLMResponse, String] =
  match resolve_cf_account() {
    err(e) => err(e)
    ok(account_id) => match require_env("CLOUDFLARE_API_KEY") {
      err(e) => err(e)
      ok(api_key) => match require_env("CLOUDFLARE_EMAIL") {
        err(_) => err("cloudflare: need CLOUDFLARE_EMAIL for Global API Key auth")
        ok(email) => {
          let sys_msgs = if opts.system != "" then [system(opts.system)] else []
          let all_msgs = sys_msgs + msgs
          let url = "https://api.cloudflare.com/client/v4/accounts/" + account_id + "/ai/run/" + model
          let body = json.object([("messages", messages_to_json(all_msgs))])
          let headers: Map[String, String] = ["X-Auth-Key": api_key, "X-Auth-Email": email, "Content-Type": "application/json"]
          match post_json(url, body, headers) {
            err(e) => err("cloudflare: " + e)
            ok(parsed) => {
              let content = json.get(parsed, "result")
                |> option.flat_map((r) => json.get_string(r, "response"))
                |> option.unwrap_or("")
              ok(empty_response(content, model))
            }
          }
        }
      }
    }
  }

// ── Provider: Azure OpenAI ──

effect fn call_azure(
  model: String, msgs: List[Message], opts: CallOptions,
) -> Result[LLMResponse, String] =
  match require_env("AZURE_OPENAI_API_KEY") {
    err(e) => err(e)
    ok(api_key) => match require_env("AZURE_OPENAI_ENDPOINT") {
      err(e) => err(e)
      ok(endpoint) => {
        let sys_msgs = if opts.system != "" then [system(opts.system)] else []
        let all_msgs = sys_msgs + msgs
        let url = endpoint + "/openai/deployments/" + model + "/chat/completions?api-version=2024-06-01"
        let fields = [
          ("messages", messages_to_json(all_msgs)),
          ("max_tokens", json.from_int(opts.max_tokens)),
        ]
        let fields = if not list.is_empty(opts.tools) then fields + [("tools", tools_to_json(opts.tools))] else fields
        let body = json.object(fields)
        let headers: Map[String, String] = ["api-key": api_key, "Content-Type": "application/json"]
        match post_json(url, body, headers) {
          err(e) => err("azure: " + e)
          ok(parsed) => {
            let choice = json.get_array(parsed, "choices")
              |> option.flat_map((cs) => list.first(cs))
              |> option.unwrap_or(json.null())
            let msg = json.get(choice, "message") |> option.unwrap_or(json.null())
            ok(LLMResponse {
              content: string.trim(extract_string(msg, "content")),
              model: model, usage: parse_usage(parsed),
              finish_reason: extract_string(choice, "finish_reason"),
              tool_calls: parse_tool_calls(msg),
            })
          }
        }
      }
    }
  }

// ── Provider: Google Gemini ──

effect fn call_google(
  model: String, msgs: List[Message], opts: CallOptions,
) -> Result[LLMResponse, String] =
  match require_env("GOOGLE_API_KEY") {
    err(e) => err(e)
    ok(api_key) => {
      let sys_msgs = if opts.system != "" then [system(opts.system)] else []
      let all_msgs = sys_msgs + msgs
      let parts = list.map(all_msgs, (m) =>
        json.object([
          ("role", json.from_string(if m.role == "assistant" then "model" else "user")),
          ("parts", json.array([json.object([("text", json.from_string(m.content))])])),
        ])
      )
      let url = "https://generativelanguage.googleapis.com/v1beta/models/" + model + ":generateContent?key=" + api_key
      let body = json.object([
        ("contents", json.array(parts)),
        ("generationConfig", json.object([("maxOutputTokens", json.from_int(opts.max_tokens))])),
      ])
      let headers: Map[String, String] = ["Content-Type": "application/json"]
      match post_json(url, body, headers) {
        err(e) => err("google: " + e)
        ok(parsed) => {
          let content = json.get_array(parsed, "candidates")
            |> option.flat_map((cands) => list.first(cands))
            |> option.flat_map((c) => json.get(c, "content"))
            |> option.flat_map((ct) => json.get_array(ct, "parts"))
            |> option.flat_map((ps) => list.first(ps))
            |> option.flat_map((p) => json.get_string(p, "text"))
            |> option.unwrap_or("")
          ok(empty_response(content, model))
        }
      }
    }
  }

// ── CLI adapters (delegated to providers.cli) ──

// ── Public API ──

effect fn call(model_spec: String, msgs: List[Message]) -> Result[LLMResponse, String] =
  call_with(model_spec, msgs, defaults())

effect fn call_with(model_spec: String, msgs: List[Message], opts: CallOptions) -> Result[LLMResponse, String] = {
  let parsed = parse_provider(model_spec)
  let provider = parsed.0
  let model = parsed.1
  match provider {
    "anthropic" => call_anthropic(model, msgs, opts),
    "openai" => match require_env("OPENAI_API_KEY") {
      err(e) => err(e)
      ok(key) => call_openai_compat("https://api.openai.com/v1", key, model, msgs, opts)
    },
    "openrouter" => match require_env("OPENROUTER_API_KEY") {
      err(e) => err(e)
      ok(key) => call_openai_compat("https://openrouter.ai/api/v1", key, model, msgs, opts)
    },
    "cf" => call_cloudflare(model, msgs, opts),
    "cloudflare" => call_cloudflare(model, msgs, opts),
    "azure" => call_azure(model, msgs, opts),
    "google" => call_google(model, msgs, opts),
    "cli" => match model {
      "claude" => cli.call_claude(msgs, opts),
      _ => err("unknown cli: " + model),
      _ => err("unknown cli: " + model),
    },
    _ => err("unknown provider: " + provider),
  }
}

// ── Response helpers ──

fn has_tool_calls(r: LLMResponse) -> Bool =
  not list.is_empty(r.tool_calls)

fn first_tool_call(r: LLMResponse) -> Option[ToolCall] =
  list.first(r.tool_calls)

fn parse_content_as_json(r: LLMResponse) -> Result[Value, String] =
  json.parse(r.content)

effect fn main() -> Unit = {}

// ── Tests ──

test "parse_provider with slash" {
  let p = parse_provider("anthropic/claude-sonnet-4-6")
  assert_eq(p.0, "anthropic")
  assert_eq(p.1, "claude-sonnet-4-6")
}

test "parse_provider no slash defaults to openai" {
  let p = parse_provider("gpt-4o")
  assert_eq(p.0, "openai")
  assert_eq(p.1, "gpt-4o")
}

test "parse_provider cloudflare" {
  let p = parse_provider("cf/@cf/meta/llama-3.3-70b")
  assert_eq(p.0, "cf")
  assert_eq(p.1, "@cf/meta/llama-3.3-70b")
}

test "message constructors" {
  assert_eq(system("s").role, "system")
  assert_eq(user("u").role, "user")
  assert_eq(assistant("a").role, "assistant")
  assert_eq(tool_result("id", "r").role, "tool")
}

test "defaults" {
  let d = defaults()
  assert_eq(d.max_tokens, 4096)
  assert_eq(d.json_mode, false)
  assert_eq(list.len(d.tools), 0)
  assert_eq(list.len(d.stop), 0)
}

test "options builder chain" {
  let opts = defaults()
    |> with_max_tokens(8192)
    |> with_system("sys")
    |> with_json_mode
    |> with_stop(["END"])
  assert_eq(opts.max_tokens, 8192)
  assert_eq(opts.system, "sys")
  assert_eq(opts.json_mode, true)
  assert_eq(list.len(opts.stop), 1)
}

test "with_tools" {
  let ts = [Tool { name: "f", description: "d", parameters: json.object([]) }]
  let opts = defaults() |> with_tools(ts)
  assert_eq(list.len(opts.tools), 1)
}

test "messages_to_json" {
  let j = json.stringify(messages_to_json([system("s"), user("u")]))
  assert(string.contains(j, "system"))
  assert(string.contains(j, "user"))
}

test "tools_to_json" {
  let ts = [Tool { name: "f", description: "d", parameters: json.object([]) }]
  let j = json.stringify(tools_to_json(ts))
  assert(string.contains(j, "function"))
}

test "parse_tool_calls empty" {
  assert_eq(list.len(parse_tool_calls(json.object([]))), 0)
}

test "parse_tool_calls with data" {
  let msg = json.object([
    ("tool_calls", json.array([
      json.object([
        ("id", json.from_string("c1")),
        ("function", json.object([
          ("name", json.from_string("greet")),
          ("arguments", json.from_string("{}")),
        ])),
      ]),
    ])),
  ])
  assert_eq(list.len(parse_tool_calls(msg)), 1)
}

test "has_tool_calls" {
  assert_eq(has_tool_calls(empty_response("hi", "m")), false)
}

test "parse_content_as_json" {
  let r = LLMResponse {
    content: "{\"x\":1}", model: "m", usage: empty_usage(),
    finish_reason: "stop", tool_calls: [],
  }
  match parse_content_as_json(r) {
    ok(v) => assert_eq(json.get_int(v, "x") |> option.unwrap_or(0), 1)
    err(_) => assert(false)
  }
}

test "empty_response" {
  let r = empty_response("hello", "test")
  assert_eq(r.content, "hello")
  assert_eq(r.model, "test")
  assert_eq(list.len(r.tool_calls), 0)
}
