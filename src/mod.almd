// almai — Multi-provider LLM client for Almide
//
// Usage:
//   import almai
//
//   let r = almai.call("anthropic/claude-sonnet-4-6", [
//     almai.system("You are helpful."),
//     almai.user("Hello"),
//   ])!
//   println(r.content)
//
// Providers: anthropic/, openai/, openrouter/, groq/, cf/, azure/, google/, cli/
// Submodules: almai.tools, almai.conv, almai.providers.*

import env
import int
import json
import self.providers.openai as openai_provider
import self.providers.anthropic as anthropic_provider
import self.providers.cloudflare as cf_provider
import self.providers.azure as azure_provider
import self.providers.google as google_provider
import self.providers.bedrock as bedrock_provider
import self.providers.cli as cli_provider

// ── Core types ──

type Message = {
  role: String,
  content: String,
  // Set on role:"tool" messages so providers (OpenAI / Anthropic) can
  // correlate the result back to the assistant's tool_use call. Empty
  // string means "not a tool result".
  tool_call_id: String = "",
  // Set on role:"assistant" messages that the model emitted with tool
  // calls. Carrying these through history is what lets providers see
  // the proper assistant → tool_result roundtrip.
  tool_calls: List[ToolCall] = [],
}

type LLMResponse = {
  content: String,
  model: String,
  usage: Usage,
  finish_reason: String,
  tool_calls: List[ToolCall],
}

type Usage = { prompt_tokens: Int, completion_tokens: Int, total_tokens: Int }
type ToolCall = { id: String, name: String, arguments: String }
type Tool = { name: String, description: String, parameters: Value }

type CallOptions = {
  max_tokens: Int,
  temperature: Float,
  top_p: Float,
  system: String,
  stop: List[String],
  tools: List[Tool],
  json_mode: Bool,
}

// ── Message constructors ──

fn system(content: String) -> Message = Message { role: "system", content: content }
fn user(content: String) -> Message = Message { role: "user", content: content }
fn assistant(content: String) -> Message = Message { role: "assistant", content: content }
fn assistant_with_tools(content: String, tool_calls: List[ToolCall]) -> Message =
  Message { role: "assistant", content: content, tool_calls: tool_calls }
fn tool_result(tool_call_id: String, content: String) -> Message =
  Message { role: "tool", content: content, tool_call_id: tool_call_id }

// ── Options builder ──

fn defaults() -> CallOptions =
  CallOptions { max_tokens: 4096, temperature: 0.0, top_p: 1.0, system: "", stop: [], tools: [], json_mode: false }

fn with_max_tokens(opts: CallOptions, n: Int) -> CallOptions = { ...opts, max_tokens: n }
fn with_temperature(opts: CallOptions, t: Float) -> CallOptions = { ...opts, temperature: t }
fn with_top_p(opts: CallOptions, p: Float) -> CallOptions = { ...opts, top_p: p }
fn with_system(opts: CallOptions, s: String) -> CallOptions = { ...opts, system: s }
fn with_stop(opts: CallOptions, sequences: List[String]) -> CallOptions = { ...opts, stop: sequences }
fn with_tools(opts: CallOptions, ts: List[Tool]) -> CallOptions = { ...opts, tools: ts }
fn with_json_mode(opts: CallOptions) -> CallOptions = { ...opts, json_mode: true }

// ── Provider parsing ──

fn parse_provider(model_spec: String) -> (String, String) = {
  let idx = string.index_of(model_spec, "/") |> option.unwrap_or(-1)
  if idx < 0 then ("openai", model_spec)
  else (string.take(model_spec, idx), string.drop(model_spec, idx + 1))
}

// ── Internal ──

effect fn require_env(key: String) -> Result[String, String] =
  match env.get(key) {
    some(v) => if v == "" then err("empty env: " + key) else ok(v)
    none => err("missing env: " + key)
  }

// ── Public API ──

effect fn call(model_spec: String, msgs: List[Message]) -> Result[LLMResponse, String] =
  call_with(model_spec, msgs, defaults())

// Streaming variant of `call_with`. Token-level deltas are delivered to
// the `on_text_delta` callback as they arrive; the final aggregated
// LLMResponse comes back via the Result.
//
// Provider support: openai, openrouter, groq (all via the shared OpenAI
// SSE wrapper). Other providers fall back with an explicit error so the
// caller can choose to retry via the non-streaming `call_with`.
effect fn call_streaming(model_spec: String, msgs: List[Message], opts: CallOptions, on_text_delta: (String) -> Unit) -> Result[LLMResponse, String] = {
  let parsed = parse_provider(model_spec)
  let provider = parsed.0
  let model = parsed.1
  match provider {
    "anthropic" => anthropic_provider.call_streaming(model, msgs, opts, on_text_delta),
    "openai" => match require_env("OPENAI_API_KEY") {
      err(e) => err(e)
      ok(key) => openai_provider.call_streaming("https://api.openai.com/v1", key, model, msgs, opts, on_text_delta)
    },
    "openrouter" => match require_env("OPENROUTER_API_KEY") {
      err(e) => err(e)
      ok(key) => openai_provider.call_streaming("https://openrouter.ai/api/v1", key, model, msgs, opts, on_text_delta)
    },
    "groq" => match require_env("GROQ_API_KEY") {
      err(e) => err(e)
      ok(key) => openai_provider.call_streaming("https://api.groq.com/openai/v1", key, model, msgs, opts, on_text_delta)
    },
    _ => err("call_streaming: provider '${provider}' does not support streaming yet (use call_with for non-streaming)")
  }
}

effect fn call_with(model_spec: String, msgs: List[Message], opts: CallOptions) -> Result[LLMResponse, String] = {
  let parsed = parse_provider(model_spec)
  let provider = parsed.0
  let model = parsed.1
  match provider {
    "anthropic" => anthropic_provider.call(model, msgs, opts),
    "openai" => match require_env("OPENAI_API_KEY") {
      err(e) => err(e)
      ok(key) => openai_provider.call("https://api.openai.com/v1", key, model, msgs, opts)
    },
    "openrouter" => match require_env("OPENROUTER_API_KEY") {
      err(e) => err(e)
      ok(key) => openai_provider.call("https://openrouter.ai/api/v1", key, model, msgs, opts)
    },
    "groq" => match require_env("GROQ_API_KEY") {
      err(e) => err(e)
      ok(key) => openai_provider.call("https://api.groq.com/openai/v1", key, model, msgs, opts)
    },
    "cf" => cf_provider.call(model, msgs, opts),
    "cloudflare" => cf_provider.call(model, msgs, opts),
    "azure" => azure_provider.call(model, msgs, opts),
    "bedrock" => bedrock_provider.call(model, msgs, opts),
    "google" => google_provider.call(model, msgs, opts),
    "cli" => match model {
      "claude" => cli_provider.call_claude(msgs, opts),
      "codex" => cli_provider.call_codex(msgs, opts),
      _ => err("unknown cli: " + model),
    },
    _ => err("unknown provider: " + provider),
  }
}

// ── Retry support ──
//
// HTTP 429 / 5xx and connection errors are transient. `call_retry` wraps the
// dispatch in an exponential-backoff loop. Non-retriable errors (auth, malformed
// request, etc.) propagate immediately. Pass `max_attempts: 1` for no retry.

fn is_retriable_error(msg: String) -> Bool =
  string.contains(msg, "429") or
  string.contains(msg, "500") or
  string.contains(msg, "502") or
  string.contains(msg, "503") or
  string.contains(msg, "504") or
  string.contains(msg, "timeout") or
  string.contains(msg, "Timeout") or
  string.contains(msg, "connection") or
  string.contains(msg, "Connection")

effect fn retry_loop(
  model_spec: String,
  msgs: List[Message],
  opts: CallOptions,
  attempt: Int,
  max_attempts: Int,
  delay_ms: Int,
) -> Result[LLMResponse, String] =
  match call_with(model_spec, msgs, opts) {
    ok(r) => ok(r)
    err(e) =>
      if attempt >= max_attempts or not is_retriable_error(e) then err(e)
      else {
        env.sleep_ms(delay_ms)
        retry_loop(model_spec, msgs, opts, attempt + 1, max_attempts, delay_ms * 2)
      }
  }

// Call with exponential backoff. Initial delay 1000ms, doubles each retry.
// `max_attempts` includes the first attempt, so 3 means 1 try + 2 retries.
effect fn call_retry(
  model_spec: String,
  msgs: List[Message],
  opts: CallOptions,
  max_attempts: Int,
) -> Result[LLMResponse, String] =
  retry_loop(model_spec, msgs, opts, 1, max_attempts, 1000)

// Call with custom initial backoff delay (ms).
effect fn call_retry_with_delay(
  model_spec: String,
  msgs: List[Message],
  opts: CallOptions,
  max_attempts: Int,
  base_delay_ms: Int,
) -> Result[LLMResponse, String] =
  retry_loop(model_spec, msgs, opts, 1, max_attempts, base_delay_ms)

// ── Response helpers ──

fn has_tool_calls(r: LLMResponse) -> Bool = not list.is_empty(r.tool_calls)
fn first_tool_call(r: LLMResponse) -> Option[ToolCall] = list.first(r.tool_calls)
fn parse_content_as_json(r: LLMResponse) -> Result[Value, String] = json.parse(r.content)

// ── Tests ──

test "parse_provider with slash" {
  let p = parse_provider("anthropic/claude-sonnet-4-6")
  assert_eq(p.0, "anthropic")
  assert_eq(p.1, "claude-sonnet-4-6")
}

test "parse_provider no slash" {
  let p = parse_provider("gpt-4o")
  assert_eq(p.0, "openai")
  assert_eq(p.1, "gpt-4o")
}

test "parse_provider cf" {
  let p = parse_provider("cf/@cf/meta/llama")
  assert_eq(p.0, "cf")
  assert_eq(p.1, "@cf/meta/llama")
}

test "message constructors" {
  assert_eq(system("s").role, "system")
  assert_eq(user("u").role, "user")
  assert_eq(assistant("a").role, "assistant")
}

test "defaults" {
  let d = defaults()
  assert_eq(d.max_tokens, 4096)
  assert_eq(d.json_mode, false)
}

test "options builder" {
  let opts = defaults() |> with_max_tokens(8192) |> with_system("sys") |> with_json_mode |> with_stop(["END"])
  assert_eq(opts.max_tokens, 8192)
  assert_eq(opts.system, "sys")
  assert_eq(opts.json_mode, true)
  assert_eq(list.len(opts.stop), 1)
}

test "with_tools" {
  let ts = [Tool { name: "f", description: "d", parameters: json.object([]) }]
  assert_eq(list.len((defaults() |> with_tools(ts)).tools), 1)
}

test "has_tool_calls false" {
  let r = LLMResponse { content: "hi", model: "m",
    usage: Usage { prompt_tokens: 0, completion_tokens: 0, total_tokens: 0 },
    finish_reason: "stop", tool_calls: [] }
  assert_eq(has_tool_calls(r), false)
}

test "is_retriable_error true for HTTP 429" {
  assert(is_retriable_error("HTTP 429: too many requests"), "429")
}

test "is_retriable_error true for HTTP 503" {
  assert(is_retriable_error("HTTP 503 Service Unavailable"), "503")
}

test "is_retriable_error true for timeout" {
  assert(is_retriable_error("request timeout after 30s"), "timeout")
  assert(is_retriable_error("Timeout reached"), "Timeout")
}

test "is_retriable_error false for auth errors" {
  assert(not is_retriable_error("HTTP 401 Unauthorized"), "401")
  assert(not is_retriable_error("HTTP 403 Forbidden"), "403")
  assert(not is_retriable_error("HTTP 400 Bad Request"), "400")
}

test "is_retriable_error false for missing env" {
  assert(not is_retriable_error("missing env: OPENAI_API_KEY"), "missing env")
}

test "parse_content_as_json" {
  let r = LLMResponse { content: "{\"x\":1}", model: "m",
    usage: Usage { prompt_tokens: 0, completion_tokens: 0, total_tokens: 0 },
    finish_reason: "stop", tool_calls: [] }
  match parse_content_as_json(r) {
    ok(v) => assert_eq(json.get_int(v, "x") |> option.unwrap_or(0), 1)
    err(_) => assert(false)
  }
}
