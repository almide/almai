// almai — Multi-provider LLM client for Almide
//
// Usage:
//   import almai
//
//   let r = almai.call("anthropic/claude-sonnet-4-6", [
//     almai.system("You are helpful."),
//     almai.user("Hello"),
//   ])!
//   println(r.content)
//
// Providers: anthropic/, openai/, openrouter/, cf/, azure/, google/, cli/
// Submodules: almai.tools, almai.conv, almai.providers.*

import env
import json
import self.providers.openai as openai_provider
import self.providers.anthropic as anthropic_provider
import self.providers.cloudflare as cf_provider
import self.providers.azure as azure_provider
import self.providers.google as google_provider
import self.providers.cli as cli_provider

// ── Core types ──

type Message = { role: String, content: String }

type LLMResponse = {
  content: String,
  model: String,
  usage: Usage,
  finish_reason: String,
  tool_calls: List[ToolCall],
}

type Usage = { prompt_tokens: Int, completion_tokens: Int, total_tokens: Int }
type ToolCall = { id: String, name: String, arguments: String }
type Tool = { name: String, description: String, parameters: Value }

type CallOptions = {
  max_tokens: Int,
  temperature: Float,
  top_p: Float,
  system: String,
  stop: List[String],
  tools: List[Tool],
  json_mode: Bool,
}

// ── Message constructors ──

fn system(content: String) -> Message = Message { role: "system", content: content }
fn user(content: String) -> Message = Message { role: "user", content: content }
fn assistant(content: String) -> Message = Message { role: "assistant", content: content }
fn tool_result(tool_call_id: String, content: String) -> Message = Message { role: "tool", content: content }

// ── Options builder ──

fn defaults() -> CallOptions =
  CallOptions { max_tokens: 4096, temperature: 0.0, top_p: 1.0, system: "", stop: [], tools: [], json_mode: false }

fn with_max_tokens(opts: CallOptions, n: Int) -> CallOptions = { ...opts, max_tokens: n }
fn with_temperature(opts: CallOptions, t: Float) -> CallOptions = { ...opts, temperature: t }
fn with_top_p(opts: CallOptions, p: Float) -> CallOptions = { ...opts, top_p: p }
fn with_system(opts: CallOptions, s: String) -> CallOptions = { ...opts, system: s }
fn with_stop(opts: CallOptions, sequences: List[String]) -> CallOptions = { ...opts, stop: sequences }
fn with_tools(opts: CallOptions, ts: List[Tool]) -> CallOptions = { ...opts, tools: ts }
fn with_json_mode(opts: CallOptions) -> CallOptions = { ...opts, json_mode: true }

// ── Provider parsing ──

fn parse_provider(model_spec: String) -> (String, String) = {
  let idx = string.index_of(model_spec, "/") |> option.unwrap_or(-1)
  if idx < 0 then ("openai", model_spec)
  else (string.take(model_spec, idx), string.drop(model_spec, idx + 1))
}

// ── Internal ──

effect fn require_env(key: String) -> Result[String, String] =
  match env.get(key) {
    some(v) => if v == "" then err("empty env: " + key) else ok(v)
    none => err("missing env: " + key)
  }

// ── Public API ──

effect fn call(model_spec: String, msgs: List[Message]) -> Result[LLMResponse, String] =
  call_with(model_spec, msgs, defaults())

effect fn call_with(model_spec: String, msgs: List[Message], opts: CallOptions) -> Result[LLMResponse, String] = {
  let parsed = parse_provider(model_spec)
  let provider = parsed.0
  let model = parsed.1
  match provider {
    "anthropic" => anthropic_provider.call(model, msgs, opts),
    "openai" => match require_env("OPENAI_API_KEY") {
      err(e) => err(e)
      ok(key) => openai_provider.call("https://api.openai.com/v1", key, model, msgs, opts)
    },
    "openrouter" => match require_env("OPENROUTER_API_KEY") {
      err(e) => err(e)
      ok(key) => openai_provider.call("https://openrouter.ai/api/v1", key, model, msgs, opts)
    },
    "cf" => cf_provider.call(model, msgs, opts),
    "cloudflare" => cf_provider.call(model, msgs, opts),
    "azure" => azure_provider.call(model, msgs, opts),
    "google" => google_provider.call(model, msgs, opts),
    "cli" => match model {
      "claude" => cli_provider.call_claude(msgs, opts),
      "codex" => cli_provider.call_codex(msgs, opts),
      _ => err("unknown cli: " + model),
    },
    _ => err("unknown provider: " + provider),
  }
}

// ── Response helpers ──

fn has_tool_calls(r: LLMResponse) -> Bool = not list.is_empty(r.tool_calls)
fn first_tool_call(r: LLMResponse) -> Option[ToolCall] = list.first(r.tool_calls)
fn parse_content_as_json(r: LLMResponse) -> Result[Value, String] = json.parse(r.content)

effect fn main() -> Unit = {}

// ── Tests ──

test "parse_provider with slash" {
  let p = parse_provider("anthropic/claude-sonnet-4-6")
  assert_eq(p.0, "anthropic")
  assert_eq(p.1, "claude-sonnet-4-6")
}

test "parse_provider no slash" {
  let p = parse_provider("gpt-4o")
  assert_eq(p.0, "openai")
  assert_eq(p.1, "gpt-4o")
}

test "parse_provider cf" {
  let p = parse_provider("cf/@cf/meta/llama")
  assert_eq(p.0, "cf")
  assert_eq(p.1, "@cf/meta/llama")
}

test "message constructors" {
  assert_eq(system("s").role, "system")
  assert_eq(user("u").role, "user")
  assert_eq(assistant("a").role, "assistant")
}

test "defaults" {
  let d = defaults()
  assert_eq(d.max_tokens, 4096)
  assert_eq(d.json_mode, false)
}

test "options builder" {
  let opts = defaults() |> with_max_tokens(8192) |> with_system("sys") |> with_json_mode |> with_stop(["END"])
  assert_eq(opts.max_tokens, 8192)
  assert_eq(opts.system, "sys")
  assert_eq(opts.json_mode, true)
  assert_eq(list.len(opts.stop), 1)
}

test "with_tools" {
  let ts = [Tool { name: "f", description: "d", parameters: json.object([]) }]
  assert_eq(list.len((defaults() |> with_tools(ts)).tools), 1)
}

test "has_tool_calls false" {
  let r = LLMResponse { content: "hi", model: "m",
    usage: Usage { prompt_tokens: 0, completion_tokens: 0, total_tokens: 0 },
    finish_reason: "stop", tool_calls: [] }
  assert_eq(has_tool_calls(r), false)
}

test "parse_content_as_json" {
  let r = LLMResponse { content: "{\"x\":1}", model: "m",
    usage: Usage { prompt_tokens: 0, completion_tokens: 0, total_tokens: 0 },
    finish_reason: "stop", tool_calls: [] }
  match parse_content_as_json(r) {
    ok(v) => assert_eq(json.get_int(v, "x") |> option.unwrap_or(0), 1)
    err(_) => assert(false)
  }
}
