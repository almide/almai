// almai.providers.openai — OpenAI-compatible (OpenAI, OpenRouter)

import env
import http
import json

type ToolCall = { id: String, name: String, arguments: String }
type Message = {
  role: String,
  content: String,
  tool_call_id: String = "",
  tool_calls: List[ToolCall] = [],
}
type LLMResponse = { content: String, model: String, usage: Usage, finish_reason: String, tool_calls: List[ToolCall] }
type Usage = { prompt_tokens: Int, completion_tokens: Int, total_tokens: Int }
type Tool = { name: String, description: String, parameters: Value }
type CallOptions = { max_tokens: Int, temperature: Float, top_p: Float, system: String, stop: List[String], tools: List[Tool], json_mode: Bool }

// Emit a single tool_call as the OpenAI Chat Completions wire shape:
//   {"id": "...", "type": "function", "function": {"name": "...", "arguments": "..."}}
fn tool_call_to_json(tc: ToolCall) -> Value =
  json.object([
    ("id", json.from_string(tc.id)),
    ("type", json.from_string("function")),
    ("function", json.object([
      ("name", json.from_string(tc.name)),
      ("arguments", json.from_string(tc.arguments)),
    ])),
  ])

fn message_to_json(m: Message) -> Value = {
  // Base shape — every message has role + content
  let base = [("role", json.from_string(m.role)), ("content", json.from_string(m.content))]
  // role:"assistant" with tool_calls → emit `tool_calls` array
  let with_tool_calls = if m.role == "assistant" and not list.is_empty(m.tool_calls) then
    base + [("tool_calls", json.array(list.map(m.tool_calls, (tc) => tool_call_to_json(tc))))]
  else base
  // role:"tool" requires `tool_call_id` to correlate with the assistant call
  let with_id = if m.role == "tool" and m.tool_call_id != "" then
    with_tool_calls + [("tool_call_id", json.from_string(m.tool_call_id))]
  else with_tool_calls
  json.object(with_id)
}

fn messages_to_json(msgs: List[Message]) -> Value =
  json.array(list.map(msgs, (m) => message_to_json(m)))

fn tools_to_json(ts: List[Tool]) -> Value =
  json.array(list.map(ts, (t) =>
    json.object([("type", json.from_string("function")), ("function", json.object([
      ("name", json.from_string(t.name)), ("description", json.from_string(t.description)), ("parameters", t.parameters)]))])))

fn parse_tool_calls(msg: Value) -> List[ToolCall] =
  json.get_array(msg, "tool_calls") |> option.unwrap_or([])
    |> list.filter_map((tc) => {
      let id = json.get_string(tc, "id") |> option.unwrap_or("")
      let func = json.get(tc, "function") |> option.unwrap_or(json.null())
      let name = json.get_string(func, "name") |> option.unwrap_or("")
      let args = json.get_string(func, "arguments") |> option.unwrap_or("{}")
      if name != "" then some(ToolCall { id: id, name: name, arguments: args }) else none
    })

fn parse_usage(v: Value) -> Usage = {
  let u = json.get(v, "usage") |> option.unwrap_or(json.null())
  Usage { prompt_tokens: json.get_int(u, "prompt_tokens") |> option.unwrap_or(0),
    completion_tokens: json.get_int(u, "completion_tokens") |> option.unwrap_or(0),
    total_tokens: json.get_int(u, "total_tokens") |> option.unwrap_or(0) }
}

effect fn post_json(url: String, body: Value, headers: Map[String, String]) -> Result[Value, String] =
  match http.request("POST", url, json.stringify(body), headers) {
    err(e) => err("http: " + e)
    ok(raw) => match json.parse(raw) {
      err(e) => err("json: " + e + " raw: " + string.take(raw, 200))
      ok(parsed) => match json.get(parsed, "error") |> option.flat_map((e) => json.get_string(e, "message")) {
        some(msg) => err("api: " + msg)
        none => ok(parsed)
      }
    }
  }

effect fn call(base_url: String, api_key: String, model: String, msgs: List[Message], opts: CallOptions) -> Result[LLMResponse, String] = {
  let sys_msgs = if opts.system != "" then [Message { role: "system", content: opts.system }] else []
  let all_msgs = sys_msgs + msgs
  let fields = [("model", json.from_string(model)), ("messages", messages_to_json(all_msgs)),
    ("max_tokens", json.from_int(opts.max_tokens)), ("temperature", json.from_float(opts.temperature))]
  let fields = if not list.is_empty(opts.tools) then fields + [("tools", tools_to_json(opts.tools))] else fields
  let fields = if opts.json_mode then fields + [("response_format", json.object([("type", json.from_string("json_object"))]))] else fields
  let fields = if not list.is_empty(opts.stop) then fields + [("stop", json.array(list.map(opts.stop, (s) => json.from_string(s))))] else fields
  match post_json(base_url + "/chat/completions", json.object(fields), ["Authorization": "Bearer " + api_key, "Content-Type": "application/json"]) {
    err(e) => err(e)
    ok(parsed) => {
      let choice = json.get_array(parsed, "choices") |> option.flat_map((cs) => list.first(cs)) |> option.unwrap_or(json.null())
      let msg = json.get(choice, "message") |> option.unwrap_or(json.null())
      ok(LLMResponse { content: string.trim(json.get_string(msg, "content") |> option.unwrap_or("")),
        model: json.get_string(parsed, "model") |> option.unwrap_or(""), usage: parse_usage(parsed),
        finish_reason: json.get_string(choice, "finish_reason") |> option.unwrap_or("stop"), tool_calls: parse_tool_calls(msg) })
    }
  }
}

test "messages_to_json" {
  let j = json.stringify(messages_to_json([Message { role: "user", content: "hi" }]))
  assert(string.contains(j, "user"))
}

test "parse_tool_calls empty" { assert_eq(list.len(parse_tool_calls(json.object([]))), 0) }
