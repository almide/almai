// almai.providers.google — Google Gemini (AI Studio / Vertex AI)

import env
import http
import json

type Message = { role: String, content: String }
type LLMResponse = { content: String, model: String, usage: Usage, finish_reason: String, tool_calls: List[ToolCall] }
type Usage = { prompt_tokens: Int, completion_tokens: Int, total_tokens: Int }
type ToolCall = { id: String, name: String, arguments: String }
type CallOptions = { max_tokens: Int, temperature: Float, top_p: Float, system: String, stop: List[String], tools: List[Tool], json_mode: Bool }
type Tool = { name: String, description: String, parameters: Value }

effect fn require_env(key: String) -> Result[String, String] =
  match env.get(key) { some(v) => if v == "" then err("empty env: " + key) else ok(v), none => err("missing env: " + key) }

effect fn call(model: String, msgs: List[Message], opts: CallOptions) -> Result[LLMResponse, String] =
  match require_env("GOOGLE_API_KEY") {
    err(e) => err(e)
    ok(api_key) => {
      let sys_msgs = if opts.system != "" then [Message { role: "system", content: opts.system }] else []
      let all_msgs = sys_msgs + msgs
      let parts = list.map(all_msgs, (m) =>
        json.object([("role", json.from_string(if m.role == "assistant" then "model" else "user")),
          ("parts", json.array([json.object([("text", json.from_string(m.content))])]))])
      )
      let url = "https://generativelanguage.googleapis.com/v1beta/models/" + model + ":generateContent?key=" + api_key
      let body = json.stringify(json.object([("contents", json.array(parts)),
        ("generationConfig", json.object([("maxOutputTokens", json.from_int(opts.max_tokens))]))]))
      match http.request("POST", url, body, ["Content-Type": "application/json"]) {
        err(e) => err("google: http: " + e)
        ok(raw) => match json.parse(raw) {
          err(e) => err("google: json: " + e)
          ok(parsed) => {
            let content = json.get_array(parsed, "candidates")
              |> option.flat_map((cands) => list.first(cands))
              |> option.flat_map((c) => json.get(c, "content"))
              |> option.flat_map((ct) => json.get_array(ct, "parts"))
              |> option.flat_map((ps) => list.first(ps))
              |> option.flat_map((p) => json.get_string(p, "text"))
              |> option.unwrap_or("")
            ok(LLMResponse { content: string.trim(content), model: model,
              usage: Usage { prompt_tokens: 0, completion_tokens: 0, total_tokens: 0 },
              finish_reason: "stop", tool_calls: [] })
          }
        }
      }
    }
  }
