// almai.providers.cloudflare — Cloudflare Workers AI

import env
import http
import json

type Message = {
  role: String,
  content: String,
  tool_call_id: String = "",
  tool_calls: List[ToolCall] = [],
}
type LLMResponse = { content: String, model: String, usage: Usage, finish_reason: String, tool_calls: List[ToolCall] }
type Usage = { prompt_tokens: Int, completion_tokens: Int, total_tokens: Int }
type ToolCall = { id: String, name: String, arguments: String }
type CallOptions = { max_tokens: Int, temperature: Float, top_p: Float, system: String, stop: List[String], tools: List[Tool], json_mode: Bool }
type Tool = { name: String, description: String, parameters: Value }

fn messages_to_json(msgs: List[Message]) -> Value =
  json.array(list.map(msgs, (m) =>
    json.object([("role", json.from_string(m.role)), ("content", json.from_string(m.content))])))

effect fn require_env(key: String) -> Result[String, String] =
  match env.get(key) { some(v) => if v == "" then err("empty env: " + key) else ok(v), none => err("missing env: " + key) }

effect fn resolve_account() -> Result[String, String] =
  match require_env("CF_ACCOUNT_ID") { ok(v) => ok(v), err(_) => require_env("CLOUDFLARE_ACCOUNT_ID") }

effect fn call(model: String, msgs: List[Message], opts: CallOptions) -> Result[LLMResponse, String] =
  match resolve_account() {
    err(e) => err(e)
    ok(account_id) => match require_env("CLOUDFLARE_API_KEY") {
      err(e) => err(e)
      ok(api_key) => match require_env("CLOUDFLARE_EMAIL") {
        err(_) => err("cloudflare: need CLOUDFLARE_EMAIL for Global API Key auth")
        ok(email) => {
          let sys_msgs = if opts.system != "" then [Message { role: "system", content: opts.system }] else []
          let url = "https://api.cloudflare.com/client/v4/accounts/" + account_id + "/ai/run/" + model
          let body = json.stringify(json.object([("messages", messages_to_json(sys_msgs + msgs))]))
          match http.request("POST", url, body, ["X-Auth-Key": api_key, "X-Auth-Email": email, "Content-Type": "application/json"]) {
            err(e) => err("cloudflare: http: " + e)
            ok(raw) => match json.parse(raw) {
              err(e) => err("cloudflare: json: " + e)
              ok(parsed) => {
                let content = json.get(parsed, "result") |> option.flat_map((r) => json.get_string(r, "response")) |> option.unwrap_or("")
                ok(LLMResponse { content: string.trim(content), model: model,
                  usage: Usage { prompt_tokens: 0, completion_tokens: 0, total_tokens: 0 },
                  finish_reason: "stop", tool_calls: [] })
              }
            }
          }
        }
      }
    }
  }
