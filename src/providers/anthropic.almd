// almai.providers.anthropic — Anthropic Messages API

import env
import http
import json

type ToolCall = { id: String, name: String, arguments: String }
type Message = {
  role: String,
  content: String,
  tool_call_id: String = "",
  tool_calls: List[ToolCall] = [],
}
type LLMResponse = { content: String, model: String, usage: Usage, finish_reason: String, tool_calls: List[ToolCall] }
type Usage = { prompt_tokens: Int, completion_tokens: Int, total_tokens: Int }
type Tool = { name: String, description: String, parameters: Value }
type CallOptions = { max_tokens: Int, temperature: Float, top_p: Float, system: String, stop: List[String], tools: List[Tool], json_mode: Bool }

// Anthropic wire format: assistant tool_use lives in `content` as a block
// array, and tool results come back as role:"user" with a `tool_result`
// content block (Anthropic does not have a separate "tool" role).

fn tool_use_block(tc: ToolCall) -> Value =
  json.object([
    ("type", json.from_string("tool_use")),
    ("id", json.from_string(tc.id)),
    ("name", json.from_string(tc.name)),
    // `arguments` is a JSON-encoded string in our generic ToolCall;
    // Anthropic expects a JSON object. Parse if possible, fall back to {}.
    ("input", match json.parse(tc.arguments) {
      ok(v) => v,
      err(_) => json.object([]),
    }),
  ])

fn text_block(content: String) -> Value =
  json.object([("type", json.from_string("text")), ("text", json.from_string(content))])

fn assistant_blocks(m: Message) -> Value = {
  let text = if m.content != "" then [text_block(m.content)] else []
  let tools = list.map(m.tool_calls, (tc) => tool_use_block(tc))
  json.array(text + tools)
}

fn tool_result_block(m: Message) -> Value =
  json.object([
    ("type", json.from_string("tool_result")),
    ("tool_use_id", json.from_string(m.tool_call_id)),
    ("content", json.from_string(m.content)),
  ])

fn message_to_json(m: Message) -> Value = {
  let role = if m.role == "tool" then "user" else m.role
  let content = if m.role == "tool" then
    json.array([tool_result_block(m)])
  else if m.role == "assistant" and not list.is_empty(m.tool_calls) then
    assistant_blocks(m)
  else
    json.from_string(m.content)
  json.object([("role", json.from_string(role)), ("content", content)])
}

fn messages_to_json(msgs: List[Message]) -> Value =
  json.array(list.map(msgs, (m) => message_to_json(m)))

fn es(v: Value, key: String) -> String = json.get_string(v, key) |> option.unwrap_or("")

effect fn require_env(key: String) -> Result[String, String] =
  match env.get(key) { some(v) => if v == "" then err("empty env: " + key) else ok(v), none => err("missing env: " + key) }

effect fn post_json(url: String, body: Value, headers: Map[String, String]) -> Result[Value, String] =
  match http.request("POST", url, json.stringify(body), headers) {
    err(e) => err("http: " + e)
    ok(raw) => match json.parse(raw) {
      err(e) => err("json: " + e)
      ok(parsed) => match json.get(parsed, "error") |> option.flat_map((e) => json.get_string(e, "message")) {
        some(msg) => err("api: " + msg)
        none => ok(parsed)
      }
    }
  }

effect fn call(model: String, msgs: List[Message], opts: CallOptions) -> Result[LLMResponse, String] =
  match require_env("ANTHROPIC_API_KEY") {
    err(e) => err(e)
    ok(api_key) => {
      let user_msgs = list.filter(msgs, (m) => m.role != "system")
      let sys = if opts.system != "" then opts.system
        else list.find(msgs, (m) => m.role == "system") |> option.map((m) => m.content) |> option.unwrap_or("")
      let fields = [("model", json.from_string(model)), ("max_tokens", json.from_int(opts.max_tokens)), ("messages", messages_to_json(user_msgs))]
      let fields = if sys != "" then fields + [("system", json.from_string(sys))] else fields
      let fields = if not list.is_empty(opts.tools) then
        fields + [("tools", json.array(list.map(opts.tools, (t) => json.object([
          ("name", json.from_string(t.name)), ("description", json.from_string(t.description)), ("input_schema", t.parameters)]))))]
      else fields
      let body = json.object(fields)
      match post_json("https://api.anthropic.com/v1/messages", body, ["x-api-key": api_key, "anthropic-version": "2023-06-01", "Content-Type": "application/json"]) {
        err(e) => err("anthropic: " + e)
        ok(parsed) => {
          let blocks = json.get_array(parsed, "content") |> option.unwrap_or([])
          let text = blocks |> list.filter_map((b) => if es(b, "type") == "text" then json.get_string(b, "text") else none) |> string.join("")
          let tc = blocks |> list.filter_map((b) =>
            if es(b, "type") == "tool_use" then some(ToolCall { id: es(b, "id"), name: es(b, "name"),
              arguments: json.get(b, "input") |> option.map((v) => json.stringify(v)) |> option.unwrap_or("{}") }) else none)
          ok(LLMResponse { content: string.trim(text), model: es(parsed, "model"),
            usage: { let u = json.get(parsed, "usage") |> option.unwrap_or(json.null())
              Usage { prompt_tokens: json.get_int(u, "prompt_tokens") |> option.unwrap_or(0),
                completion_tokens: json.get_int(u, "completion_tokens") |> option.unwrap_or(0),
                total_tokens: json.get_int(u, "total_tokens") |> option.unwrap_or(0) } },
            finish_reason: es(parsed, "stop_reason"), tool_calls: tc })
        }
      }
    }
  }

// Build the Messages API request body. Mirrors `call`'s body
// construction so streaming + non-streaming share the wire format.
fn build_body(model: String, msgs: List[Message], opts: CallOptions, stream: Bool) -> Value = {
  let user_msgs = list.filter(msgs, (m) => m.role != "system")
  let sys = if opts.system != "" then opts.system
    else list.find(msgs, (m) => m.role == "system") |> option.map((m) => m.content) |> option.unwrap_or("")
  let fields = [("model", json.from_string(model)), ("max_tokens", json.from_int(opts.max_tokens)), ("messages", messages_to_json(user_msgs))]
  let fields = if sys != "" then fields + [("system", json.from_string(sys))] else fields
  let fields = if not list.is_empty(opts.tools) then
    fields + [("tools", json.array(list.map(opts.tools, (t) => json.object([
      ("name", json.from_string(t.name)), ("description", json.from_string(t.description)), ("input_schema", t.parameters)]))))]
  else fields
  let fields = if stream then fields + [("stream", json.from_bool(true))] else fields
  json.object(fields)
}

// Streaming call. Routes through almide's `http.anthropic_streaming_call`
// intrinsic which handles the (event:/data:) SSE wire shape and
// content_block_start / content_block_delta / message_delta accumulation.
// Returns the same shape as `openai.call_streaming`.
effect fn call_streaming(model: String, msgs: List[Message], opts: CallOptions, on_text_delta: (String) -> Unit) -> Result[LLMResponse, String] =
  match require_env("ANTHROPIC_API_KEY") {
    err(e) => err(e)
    ok(api_key) => {
      let body_json = json.stringify(build_body(model, msgs, opts, true))
      match http.anthropic_streaming_call(api_key, body_json, on_text_delta) {
        err(e) => err("anthropic streaming: " + e)
        ok(raw) => match json.parse(raw) {
          err(e) => err("anthropic streaming: parse aggregate: " + e)
          ok(parsed) => {
            let tool_calls_arr = json.get_array(parsed, "tool_calls") |> option.unwrap_or([])
            let tool_calls = tool_calls_arr |> list.filter_map((tc) => {
              let id = json.get_string(tc, "id") |> option.unwrap_or("")
              let name = json.get_string(tc, "name") |> option.unwrap_or("")
              let args = json.get_string(tc, "arguments") |> option.unwrap_or("{}")
              if name != "" then some(ToolCall { id: id, name: name, arguments: args }) else none
            })
            let usage_obj = json.get(parsed, "usage") |> option.unwrap_or(json.null())
            ok(LLMResponse {
              content: json.get_string(parsed, "content") |> option.unwrap_or(""),
              model: json.get_string(parsed, "model") |> option.unwrap_or(""),
              usage: Usage {
                prompt_tokens: json.get_int(usage_obj, "prompt_tokens") |> option.unwrap_or(0),
                completion_tokens: json.get_int(usage_obj, "completion_tokens") |> option.unwrap_or(0),
                total_tokens: json.get_int(usage_obj, "total_tokens") |> option.unwrap_or(0),
              },
              finish_reason: json.get_string(parsed, "finish_reason") |> option.unwrap_or("end_turn"),
              tool_calls: tool_calls,
            })
          }
        }
      }
    }
  }
