// almai.providers.bedrock — AWS Bedrock (Anthropic models)
//
// Uses Bedrock's Converse API with SigV4 signing.
// Env vars: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION

import env
import http
import json
import datetime

type Message = { role: String, content: String }
type LLMResponse = { content: String, model: String, usage: Usage, finish_reason: String, tool_calls: List[ToolCall] }
type Usage = { prompt_tokens: Int, completion_tokens: Int, total_tokens: Int }
type ToolCall = { id: String, name: String, arguments: String }
type CallOptions = { max_tokens: Int, temperature: Float, top_p: Float, system: String, stop: List[String], tools: List[Tool], json_mode: Bool }
type Tool = { name: String, description: String, parameters: Value }

effect fn require_env(key: String) -> Result[String, String] =
  match env.get(key) { some(v) => if v == "" then err("empty env: " + key) else ok(v), none => err("missing env: " + key) }

effect fn call(model: String, msgs: List[Message], opts: CallOptions) -> Result[LLMResponse, String] =
  match require_env("AWS_ACCESS_KEY_ID") {
    err(e) => err("bedrock: " + e)
    ok(access_key) => match require_env("AWS_SECRET_ACCESS_KEY") {
      err(e) => err("bedrock: " + e)
      ok(secret_key) => {
        let region = env.get("AWS_REGION") |> option.unwrap_or("us-east-1")
        let url = "https://bedrock-runtime." + region + ".amazonaws.com/model/" + model + "/converse"
        let messages = json.array(list.map(
          list.filter(msgs, (m) => m.role != "system"),
          (m) => json.object([
            ("role", json.from_string(m.role)),
            ("content", json.array([json.object([("text", json.from_string(m.content))])])),
          ])
        ))
        let sys = if opts.system != "" then opts.system
          else list.find(msgs, (m) => m.role == "system") |> option.map((m) => m.content) |> option.unwrap_or("")
        let fields = [("messages", messages), ("inferenceConfig", json.object([("maxTokens", json.from_int(opts.max_tokens))]))]
        let fields = if sys != "" then
          fields + [("system", json.array([json.object([("text", json.from_string(sys))])]))]
        else fields
        let body = json.stringify(json.object(fields))

        // Note: Full SigV4 signing requires HMAC-SHA256 which Almide stdlib doesn't yet support.
        // For now, this provider works when called through an AWS SDK proxy or when
        // AWS_SESSION_TOKEN is available (e.g., IAM role with temporary credentials via aws-vault).
        // TODO: Implement SigV4 signing when bytes.hmac_sha256 is available.
        let headers: Map[String, String] = [
          "Content-Type": "application/json",
          "X-Amz-Security-Token": env.get("AWS_SESSION_TOKEN") |> option.unwrap_or(""),
        ]
        match http.request("POST", url, body, headers) {
          err(e) => err("bedrock: http: " + e)
          ok(raw) => match json.parse(raw) {
            err(e) => err("bedrock: json: " + e)
            ok(parsed) => {
              let content = json.get(parsed, "output")
                |> option.flat_map((o) => json.get(o, "message"))
                |> option.flat_map((m) => json.get_array(m, "content"))
                |> option.flat_map((cs) => list.first(cs))
                |> option.flat_map((c) => json.get_string(c, "text"))
                |> option.unwrap_or("")
              let u = json.get(parsed, "usage") |> option.unwrap_or(json.null())
              ok(LLMResponse {
                content: string.trim(content), model: model,
                usage: Usage {
                  prompt_tokens: json.get_int(u, "inputTokens") |> option.unwrap_or(0),
                  completion_tokens: json.get_int(u, "outputTokens") |> option.unwrap_or(0),
                  total_tokens: json.get_int(u, "totalTokens") |> option.unwrap_or(0),
                },
                finish_reason: json.get_string(parsed, "stopReason") |> option.unwrap_or("end_turn"),
                tool_calls: [],
              })
            }
          }
        }
      }
    }
  }
