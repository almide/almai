import self as almai
import json

test "message constructors" {
  assert_eq(almai.system("s").role, "system")
  assert_eq(almai.user("u").role, "user")
  assert_eq(almai.assistant("a").role, "assistant")
}

test "options builder" {
  let opts = almai.defaults()
    |> almai.with_max_tokens(8192)
    |> almai.with_temperature(0.7)
    |> almai.with_system("sys")
    |> almai.with_stop(["END"])
    |> almai.with_json_mode
  assert_eq(opts.max_tokens, 8192)
  assert_eq(opts.system, "sys")
  assert_eq(opts.json_mode, true)
}

test "tool construction" {
  let t = Tool { name: "get_weather", description: "Get weather", parameters: json.object([]) }
  assert_eq(t.name, "get_weather")
}

test "response helpers" {
  let u = Usage { prompt_tokens: 10, completion_tokens: 5, total_tokens: 15 }
  let r = LLMResponse {
    content: "{\"x\":1}", model: "test", usage: u,
    finish_reason: "stop", tool_calls: [],
  }
  assert_eq(almai.has_tool_calls(r), false)
  assert_eq(r.usage.total_tokens, 15)
}

test "with_tools" {
  let ts = [Tool { name: "f", description: "d", parameters: json.object([]) }]
  let opts = almai.defaults() |> almai.with_tools(ts)
  assert_eq(list.len(opts.tools), 1)
}

test "tool_result constructor sets tool_call_id" {
  let m = almai.tool_result("call_abc", "42")
  assert_eq(m.role, "tool")
  assert_eq(m.content, "42")
  assert_eq(m.tool_call_id, "call_abc")
}

test "assistant_with_tools preserves tool_calls" {
  let tcs = [ToolCall { id: "c1", name: "Read", arguments: "{\"path\":\"/a\"}" }]
  let m = almai.assistant_with_tools("calling tool", tcs)
  assert_eq(m.role, "assistant")
  assert_eq(m.content, "calling tool")
  assert_eq(list.len(m.tool_calls), 1)
}

test "default fields apply to legacy constructors" {
  // user / system / assistant should still work with no tool fields supplied
  let u = almai.user("hi")
  assert_eq(u.tool_call_id, "")
  assert_eq(list.len(u.tool_calls), 0)
}
